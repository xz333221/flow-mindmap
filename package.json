{
  "name": "z-mind",
  "version": "0.1.0",
  "description": "A modern, minimalist mind mapping tool — xmind-style, embeddable as a Vue component.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "xuze",
    "email": "569552263@qq.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xuze/z-mind.git"
  },
  "bugs": {
    "url": "https://github.com/xuze/z-mind/issues"
  },
  "keywords": [
    "mindmap",
    "mind-map",
    "xmind",
    "vue",
    "vue3",
    "vite",
    "svg",
    "canvas",
    "tree"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/z-mind.umd.cjs",
  "module": "./dist/z-mind.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/z-mind.js",
      "require": "./dist/z-mind.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite --port 7851 --strictPort",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 7852",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.ts,.js --max-warnings 0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^5.1.4",
    "playwright": "^1.60.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vue": "^3.5.12",
    "vue-tsc": "^2.1.10"
  }
}
